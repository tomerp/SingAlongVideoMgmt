# Database - PostgreSQL (local or Cloud SQL)
DATABASE_URL="postgresql://user:password@localhost:5432/singalong?schema=public"

# Auth - single user
AUTH_USERNAME="admin"
AUTH_PASSWORD_HASH=""  # Generate: node -e "console.log(require('bcryptjs').hashSync('admin', 10))"
AUTH_SESSION_SECRET=""  # Random string for session cookies

# YouTube (optional) - omit to use mock data
YOUTUBE_API_KEY=""

# YouTube OAuth - for "Connect YouTube" to sync unlisted videos
# Create OAuth 2.0 credentials (not API key) in Google Cloud Console
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Add redirect URI in Google Cloud Console: http://localhost:3000/api/auth/youtube/callback
# For production: set NEXTAUTH_URL or APP_URL (e.g. https://yoursite.com) so OAuth redirect works

USE_MOCK_YOUTUBE="true"  # Set to force mock even with API key
